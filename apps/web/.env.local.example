# Copy this file to .env.local for local development (e.g. cp .env.local.example .env.local).
# API base URL for the Next.js frontend. When not set, API requests go to the same origin (Next.js),
# which returns HTML for unknown paths and causes "Unexpected token '<'" when parsing as JSON.
# Set this to your Express API origin (e.g. http://localhost:4000).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: inject at runtime via a script in layout instead of build-time env:
# window.__API_BASE = "http://localhost:4000";
# window.__API_KEY = "your-platform-or-firm-api-key";
