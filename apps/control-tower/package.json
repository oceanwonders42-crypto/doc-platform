{
  "name": "control-tower",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3400",
    "build": "next build",
    "start": "next start --port 3400",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "node prisma/init.mjs",
    "db:seed": "node prisma/seed.mjs",
    "db:setup": "pnpm db:push && pnpm db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
