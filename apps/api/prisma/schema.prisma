generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLATFORM_ADMIN
  FIRM_ADMIN
  STAFF
}

enum DocumentStatus {
  RECEIVED
  PROCESSING
  SCANNED
  CLASSIFIED
  ROUTED
  NEEDS_REVIEW
  UPLOADED
  FAILED
  UNMATCHED
}

enum ProcessingStage {
  uploaded
  ocr
  classification
  extraction
  case_match
  complete
}

model Firm {
  id                   String    @id @default(cuid())
  name                 String
  plan                 String    @default("starter")
  pageLimitMonthly     Int       @default(5000)
  retentionDays        Int       @default(7)
  status               String    @default("active")
  billingCustomerId    String?
  billingStatus        String    @default("trial")
  trialEndsAt          DateTime?
  features             Json?
  settings             Json?
  createdAt            DateTime  @default(now())

  users          User[]
  apiKeys        ApiKey[]
  documents      Document[]
  usageMonthly   UsageMonthly[]
  routingRule    RoutingRule?
  providers      Provider[]
  cases          LegalCase[]
  caseProviders  CaseProvider[]
  crmPushLogs    CrmPushLog[]
  crmCaseMappings CrmCaseMapping[]
  notifications  Notification[]
  jobs           Job[]
  webhookEndpoints WebhookEndpoint[]
  reviewQueueEvents ReviewQueueEvent[]
  referrals      Referral[]
  caseSummaries  CaseSummary[]
  caseChecklistItems CaseChecklistItem[]
  casePacketExports CasePacketExport[]
  activityFeedItems ActivityFeedItem[]
  savedViews        SavedView[]
  caseFinancials    CaseFinancial[]
  documentTags      DocumentTag[]
  caseContacts      CaseContact[]
  demandPackages    DemandPackage[]
  demandPackageSectionSources DemandPackageSectionSource[]
  extractionFeedback ExtractionFeedback[]
  firmIntegrations   FirmIntegration[]
  mailboxConnections MailboxConnection[]
  medicalBillLineItems MedicalBillLineItem[]
}

model SavedView {
  id          String   @id @default(cuid())
  firmId      String
  userId      String?
  name        String
  scope        String   // e.g. "dashboard" | "review_queue"
  filtersJson Json
  createdAt   DateTime @default(now())

  firm Firm  @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([userId])
  @@index([firmId, scope])
}

enum JobStatus {
  queued
  running
  failed
  done
  cancelled
}

model Job {
  id          String    @id @default(cuid())
  firmId      String?
  type        String    // document.process | document.reprocess | records_request.send | demand_package.generate | timeline.rebuild | export.packet | document.thumbnail.generate
  status      JobStatus @default(queued)
  payload     Json
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  priority    Int       @default(100)
  runAt       DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?    @db.Text
  resultMeta  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  finishedAt  DateTime?

  firm    Firm?       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  events  JobEvent[]

  @@index([status, runAt, priority])
  @@index([firmId, status])
  @@index([type, status])
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  level     String   // info | warn | error
  message   String   @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model User {
  id           String    @id @default(cuid())
  firmId       String
  email        String    @unique
  passwordHash String?
  role         Role      @default(STAFF)
  createdAt    DateTime  @default(now())

  firm        Firm         @relation(fields: [firmId], references: [id])
  savedViews  SavedView[]
}

model ApiKey {
  id         String    @id @default(cuid())
  firmId     String
  userId     String?
  name       String
  keyPrefix  String
  keyHash    String
  scopes     String    @default("ingest")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
}

model Document {
  id           String         @id @default(cuid())
  firmId       String
  source       String
  spacesKey    String
  originalName String
  mimeType     String
  pageCount    Int            @default(0)
  status       DocumentStatus @default(RECEIVED)
  processingStage ProcessingStage @default(uploaded)
  external_id  String?
  file_sha256  String?
  fileSizeBytes Int?
  duplicateMatchCount Int @default(0)
  duplicateOfId String?
  duplicateConfidence Float?
  ingestedAt   DateTime @default(now())

  extractedFields Json?
  confidence      Float?
  routedSystem    String?
  routedCaseId    String?
  routingStatus   String?

  thumbnailKey    String?

  createdAt   DateTime @default(now())
  processedAt DateTime?

  metaJson    Json?

  failureStage  String?   // ingest | fetch | page_count | ocr | recognition_save | classification | extraction | case_match | timeline
  failureReason String?   @db.Text

  duplicateOf   Document?  @relation("DocumentDuplicate", fields: [duplicateOfId], references: [id])
  duplicates    Document[] @relation("DocumentDuplicate")

  firm Firm @relation(fields: [firmId], references: [id])

  auditEvents DocumentAuditEvent[]
  activityFeedItems ActivityFeedItem[]
  tagLinks    DocumentTagLink[]
  versions    DocumentVersion[]
  medicalBillLineItems MedicalBillLineItem[]

  @@index([firmId])
  @@index([status])
  @@index([firmId, file_sha256])
  @@index([firmId, createdAt])
  @@index([firmId, status])
  @@index([firmId, routedCaseId])
  @@index([firmId, failureStage])
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  versionNumber Int
  spacesKey    String
  createdAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model DocumentTag {
  id      String  @id @default(cuid())
  firmId  String
  name    String
  color   String?

  firm   Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  links  DocumentTagLink[]

  @@index([firmId])
}

model DocumentTagLink {
  id         String @id @default(cuid())
  documentId String
  tagId      String

  document Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      DocumentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
  @@index([documentId])
  @@index([tagId])
}

model RoutingRule {
  id                    String   @id @default(cuid())
  firmId                String   @unique
  minAutoRouteConfidence Float    @default(0.9)
  autoRouteEnabled       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])
}

model RoutingFeedback {
  id               String    @id @default(cuid())
  firmId           String
  documentId       String
  predictedCaseId String?
  finalCaseId      String?
  predictedStatus  String?
  finalStatus      String?
  predictedDocType String?
  finalDocType     String?
  confidence       Float?
  correctedBy      String?
  wasAccepted      Boolean   @default(false)
  featuresJson     Json?
  createdAt        DateTime  @default(now())

  @@index([firmId, documentId])
  @@index([firmId, wasAccepted])
}

model RoutingPattern {
  id              String   @id @default(cuid())
  firmId          String
  name            String
  docType         String?
  providerName    String?
  source          String?
  fileNamePattern String?
  keywordsJson    Json?
  targetCaseId    String?
  targetFolder    String?
  priority        Int      @default(100)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([firmId, active, priority])
}

model RoutingScoreSnapshot {
  id             String   @id @default(cuid())
  firmId         String
  documentId     String
  chosenCaseId   String?
  chosenFolder   String?
  chosenDocType  String?
  confidence     Float?
  signalsJson    Json?
  candidatesJson Json?
  createdAt      DateTime @default(now())

  @@index([firmId, documentId])
}

model ExtractionFeedback {
  id                String   @id @default(cuid())
  firmId            String
  documentId        String
  fieldKey          String
  predictedValue    String?  @db.Text
  correctedValue    String?  @db.Text
  wasCorrect        Boolean
  correctedBy       String?
  createdAt         DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, documentId])
  @@index([firmId, fieldKey])
}

model DocumentAuditEvent {
  id         String   @id @default(cuid())
  documentId String
  firmId     String
  actor      String
  action     String
  fromCaseId String?
  toCaseId   String?
  metaJson   Json?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([firmId])
  @@index([action])
  @@index([firmId, createdAt])
}

model UsageMonthly {
  id                     String   @id @default(cuid())
  firmId                 String
  yearMonth              String
  pagesProcessed         Int      @default(0)
  docsProcessed          Int      @default(0)
  insuranceDocsExtracted Int      @default(0)
  courtDocsExtracted     Int      @default(0)
  narrativeGenerated     Int      @default(0)
  duplicateDetected      Int      @default(0)
  updatedAt              DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])

  @@unique([firmId, yearMonth])
  @@index([firmId])
}

model Provider {
  id               String    @id @default(cuid())
  firmId           String
  name             String
  address          String
  city             String
  state            String
  phone            String?
  fax              String?
  email            String?
  specialty        String?
  specialtiesJson  Json?
  verified         Boolean   @default(false)
  subscriptionTier String    @default("free")
  listingActive    Boolean   @default(true)
  expiresAt        DateTime?
  lat              Float?
  lng              Float?
  createdAt        DateTime  @default(now())
  hoursJson        Json?
  serviceAreasJson Json?
  intakeInstructions String?  @db.Text

  firm              Firm              @relation(fields: [firmId], references: [id])
  caseProviders     CaseProvider[]
  providerAccounts  ProviderAccount[]
  providerInvites   ProviderInvite[]
  invoices          ProviderInvoice[]
  referrals         Referral[]
  activityFeedItems ActivityFeedItem[]

  @@index([firmId])
}

model ProviderInvoice {
  id              String    @id @default(cuid())
  providerId      String
  amountCents     Int
  status          String    @default("open")
  billingPeriod   String
  dueAt           DateTime?
  paidAt          DateTime?
  stripeInvoiceId String?
  createdAt       DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
}

model ProviderAccount {
  id          String   @id @default(cuid())
  providerId  String
  email       String   @unique
  passwordHash String
  role        String   @default("PROVIDER_ADMIN")
  createdAt   DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model ProviderInvite {
  id          String    @id @default(cuid())
  providerId  String
  email       String
  tokenHash   String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([email])
}

model CaseProvider {
  id           String   @id @default(cuid())
  firmId       String
  caseId       String
  providerId   String
  relationship String   @default("treating") // treating | referral | lien | records_only
  createdAt    DateTime @default(now())

  firm     Firm     @relation(fields: [firmId], references: [id])
  case    LegalCase @relation(fields: [caseId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([firmId, caseId, providerId])
  @@index([firmId, providerId])
}

model RecordsRequest {
  id                 String    @id @default(cuid())
  firmId             String
  caseId             String
  providerId         String?
  providerName       String
  providerContact   String?
  dateFrom          DateTime?
  dateTo            DateTime?
  requestDate       DateTime?
  responseDate      DateTime?
  notes             String?
  letterBody        String?   // AI-generated request letter text (fax/email ready)
  status            String    @default("DRAFT")
  generatedDocumentId String? // Document created by Generate PDF
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // --- Records request automation fields ---
  patientName        String?
  patientDob        DateTime?
  dateOfLoss        DateTime?
  requestType       String?   // RECORDS | BILLS | BOTH
  destinationType   String?   // EMAIL | FAX | PORTAL | MANUAL
  destinationValue  String?
  subject           String?   @db.Text
  messageBody       String?   @db.Text
  requestedDateFrom DateTime?
  requestedDateTo   DateTime?
  sentAt            DateTime?
  dueAt             DateTime?
  completedAt       DateTime?
  createdByUserId  String?
  followUpCount     Int       @default(0)
  lastFollowUpAt    DateTime?

  attempts   RecordsRequestAttempt[]
  attachments RecordsRequestAttachment[]
  events     RecordsRequestEvent[]

  @@index([firmId, caseId])
  @@index([firmId, providerId])
  @@index([firmId, status])
  @@index([firmId, dueAt])
  @@index([firmId, createdAt])
}

model RecordsRequestAttachment {
  id               String   @id @default(cuid())
  firmId           String
  recordsRequestId String
  documentId       String
  kind             String   // AUTHORIZATION | LETTER | SUPPORTING_DOC | RESPONSE_DOC
  createdAt        DateTime @default(now())

  recordsRequest RecordsRequest @relation(fields: [recordsRequestId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([recordsRequestId])
}

model RecordsRequestEvent {
  id               String   @id @default(cuid())
  firmId           String
  recordsRequestId String
  eventType        String   // CREATED | SENT | FOLLOW_UP_SENT | RESPONSE_RECEIVED | STATUS_CHANGED | FAILED | NOTE_ADDED
  status           String?
  message          String?   @db.Text
  metaJson         Json?
  createdAt        DateTime @default(now())

  recordsRequest RecordsRequest @relation(fields: [recordsRequestId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([recordsRequestId])
  @@index([createdAt])
}

model RecordsRequestTemplate {
  id          String   @id @default(cuid())
  firmId      String
  name        String
  requestType String?  // RECORDS | BILLS | BOTH
  subject     String?  @db.Text
  body        String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firmId])
}

model RecordsRequestFollowUpRule {
  id              String   @id @default(cuid())
  firmId          String
  enabled         Boolean  @default(true)
  daysAfterSend   Int      @default(14)
  maxFollowUps    Int      @default(3)
  messageTemplate String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([firmId])
}

model RecordsRequestAttempt {
  id                 String   @id @default(cuid())
  firmId             String
  recordsRequestId   String
  channel           String   // email | fax
  destination       String?
  ok                Boolean
  error             String?  @db.Text
  externalId        String?
  createdAt         DateTime @default(now())

  recordsRequest RecordsRequest @relation(fields: [recordsRequestId], references: [id], onDelete: Cascade)

  @@index([firmId, recordsRequestId])
  @@index([recordsRequestId])
}

model LegalCase {
  id          String   @id @default(cuid())
  firmId      String
  title       String?
  caseNumber  String?
  clientName  String?
  status      String   @default("open") // open | pending | closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firm          Firm          @relation(fields: [firmId], references: [id])
  caseProviders CaseProvider[]
  caseNotes     CaseNote[]
  caseTasks     CaseTask[]
  referrals     Referral[]
  caseSummaries CaseSummary[]
  caseChecklistItems CaseChecklistItem[]
  casePacketExports CasePacketExport[]
  activityFeedItems ActivityFeedItem[]
  caseFinancial     CaseFinancial?
  caseContacts      CaseContact[]
  demandPackages    DemandPackage[]
  medicalBillLineItems MedicalBillLineItem[]

  @@index([firmId])
  @@map("Case")
  @@index([firmId, createdAt])
}

model CaseFinancial {
  id                 String    @id @default(cuid())
  firmId             String
  caseId             String    @unique
  medicalBillsTotal  Float     @default(0)
  liensTotal         Float     @default(0)
  settlementOffer    Float?
  settlementAccepted Float?
  attorneyFees       Float?
  costs              Float?
  netToClient        Float?
  updatedAt          DateTime  @updatedAt

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([firmId, caseId])
  @@index([caseId])
}

model MedicalBillLineItem {
  id                   String    @id @default(cuid())
  firmId               String
  caseId               String
  documentId           String
  providerName         String?
  serviceDate          DateTime?
  cptCode              String?
  procedureDescription String?
  amountCharged        Float?
  amountPaid           Float?
  balance              Float?
  lineTotal            Float?
  createdAt            DateTime  @default(now())

  firm     Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case     LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([documentId])
  @@index([firmId])
}

model CaseNote {
  id            String   @id @default(cuid())
  firmId        String
  caseId        String
  authorUserId  String?
  body          String   @db.Text
  createdAt     DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId, caseId])
  @@index([caseId])
}

model CaseTask {
  id          String    @id @default(cuid())
  firmId      String
  caseId      String
  title       String
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId, caseId])
  @@index([caseId])
  @@index([firmId, completedAt])
}

model Referral {
  id          String    @id @default(cuid())
  firmId      String
  caseId      String
  providerId  String
  referredAt  DateTime  @default(now())
  status      String    @default("sent")
  notes       String?   @db.Text

  firm     Firm      @relation(fields: [firmId], references: [id])
  case     LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  provider Provider  @relation(fields: [providerId], references: [id])

  @@index([firmId])
  @@index([caseId])
  @@index([providerId])
}

model CaseSummary {
  id        String   @id @default(cuid())
  firmId    String
  caseId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([firmId, caseId])
  @@index([firmId])
  @@index([caseId])
}

model CaseChecklistItem {
  id        String   @id @default(cuid())
  firmId    String
  caseId    String
  key       String
  label     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([firmId, caseId, key])
  @@index([firmId])
  @@index([caseId])
}

model CasePacketExport {
  id         String   @id @default(cuid())
  firmId     String
  caseId     String
  storageKey String   // S3 key for the ZIP file
  fileName   String   // e.g. case-packet-2024-04-15.zip, case-records-2024-04-15.zip
  packetType String   @default("combined") // combined | records | bills
  createdAt  DateTime @default(now())

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([caseId])
  @@index([createdAt])
}

model CaseContact {
  id        String   @id @default(cuid())
  firmId    String
  caseId    String
  name      String
  role      String
  phone     String?
  email     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([caseId])
}

model DemandPackage {
  id                String    @id @default(cuid())
  firmId            String
  caseId            String
  title             String
  status            String    @default("draft") // draft | generating | ready | failed
  summaryText       String?   @db.Text
  damagesText       String?   @db.Text
  liabilityText     String?   @db.Text
  treatmentText    String?   @db.Text
  futureCareText   String?   @db.Text
  settlementText   String?   @db.Text
  generatedDocId    String?
  generatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  firm   Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case   LegalCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sectionSources DemandPackageSectionSource[]

  @@index([firmId, caseId])
}

model DemandPackageSectionSource {
  id               String   @id @default(cuid())
  firmId           String
  demandPackageId  String
  sectionKey       String   // summary | liability | treatment | damages | future_care | settlement
  documentId       String?
  timelineEventId  String?
  sourceType       String   // document | timeline | financial | summary | note
  sourceMeta       Json?
  createdAt        DateTime @default(now())

  firm          Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  demandPackage DemandPackage @relation(fields: [demandPackageId], references: [id], onDelete: Cascade)

  @@index([firmId, demandPackageId])
}

model ActivityFeedItem {
  id          String    @id @default(cuid())
  firmId      String
  caseId      String?
  providerId  String?
  documentId  String?
  type        String
  title       String
  meta        Json?
  createdAt   DateTime  @default(now())

  firm     Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case     LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  provider Provider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  document Document?  @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([caseId])
  @@index([createdAt])
}

model CaseTimelineEvent {
  id          String    @id @default(cuid())
  caseId      String
  firmId      String
  eventDate   DateTime?
  eventType   String?
  track       String    @default("medical")
  facilityId  String?
  provider    String?
  diagnosis   String?
  procedure   String?
  amount      String?
  documentId  String
  metadataJson Json?
  createdAt   DateTime  @default(now())

  @@index([caseId, firmId])
  @@index([documentId])
  @@index([caseId, firmId, track])
}

model CaseTimelineRebuild {
  id        String   @id @default(cuid())
  caseId    String
  firmId    String
  rebuiltAt DateTime @default(now())

  @@unique([caseId, firmId])
  @@index([caseId])
}

model CrmPushLog {
  id          String   @id @default(cuid())
  firmId      String
  caseId      String
  documentId  String?
  actionType  String
  provider    String
  ok          Boolean
  externalId  String?
  error       String?
  createdAt   DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
  @@index([caseId])
  @@index([createdAt])
}

model CrmCaseMapping {
  id                String   @id @default(cuid())
  firmId            String
  caseId            String   // internal LegalCase id
  externalMatterId  String   // CRM matter/m case id
  createdAt         DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@unique([firmId, caseId])
  @@index([firmId])
  @@index([externalMatterId])
}

model SystemErrorLog {
  id         String    @id @default(cuid())
  service    String
  message    String    @db.Text
  stack      String?   @db.Text
  createdAt  DateTime  @default(now())
  firmId     String?
  userId     String?
  area       String?
  route      String?
  method     String?
  severity   String?   // INFO | WARN | ERROR | CRITICAL
  metaJson   Json?
  resolvedAt DateTime?
  status     String?   // OPEN | ACKNOWLEDGED | RESOLVED

  @@index([service])
  @@index([createdAt])
  @@index([firmId])
  @@index([severity])
  @@index([status])
}

model AppBugReport {
  id           String   @id @default(cuid())
  firmId       String
  userId       String?
  title        String   @db.Text
  description  String   @db.Text
  pageUrl      String?  @db.Text
  screenshotUrl String?
  status       String   @default("OPEN")   // OPEN | IN_PROGRESS | CLOSED
  priority     String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([firmId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model SystemBackup {
  id         String   @id @default(cuid())
  backupType String   // DB | FILE_STORAGE | CONFIG
  location   String   @db.Text
  size       Int      @default(0)
  checksum   String?
  createdAt  DateTime @default(now())
  verifiedAt DateTime?
  status     String   // SUCCESS | FAILED

  @@index([backupType])
  @@index([createdAt])
  @@index([status])
}

model SystemIncident {
  id              String    @id @default(cuid())
  severity        String    // LOW | MEDIUM | HIGH | CRITICAL
  title           String    @db.Text
  description     String?   @db.Text
  status          String    // OPEN | MITIGATING | RESOLVED
  relatedErrorId  String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  firmId    String
  type      String   // settlement_offer_detected | timeline_updated | narrative_generated
  title     String
  message   String?  @db.Text
  meta      Json?    // e.g. { caseId, documentId, amount }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
  @@index([firmId, read])
  @@index([createdAt])
}

model ReviewQueueEvent {
  id             String    @id @default(cuid())
  firmId         String
  documentId     String
  enteredAt      DateTime
  exitedAt       DateTime?
  resolutionType String?

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, documentId])
  @@index([firmId, enteredAt])
  @@index([exitedAt])
}

model WebhookEndpoint {
  id         String   @id @default(cuid())
  firmId     String
  url        String   @db.Text
  secret     String   @db.Text
  eventsJson Json?    // JSON array of event names e.g. ["document.processed", "document.routed"]
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
}

// --- Firm Integration (email + case API onboarding) ---
enum IntegrationType {
  EMAIL
  CASE_API
}

enum IntegrationProvider {
  GMAIL
  OUTLOOK
  CLIO
  FILEVINE
  GENERIC
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum MailboxProvider {
  GMAIL
  OUTLOOK
  IMAP
}

model FirmIntegration {
  id        String            @id @default(cuid())
  firmId    String
  type      IntegrationType
  provider  IntegrationProvider
  status    IntegrationStatus @default(DISCONNECTED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  firm             Firm                  @relation(fields: [firmId], references: [id], onDelete: Cascade)
  credentials      IntegrationCredential[]
  syncLogs         IntegrationSyncLog[]
  fieldMappings    FieldMapping[]
  mailboxConnections MailboxConnection[]

  @@index([firmId])
  @@index([firmId, type])
  @@index([status])
}

model IntegrationCredential {
  id              String    @id @default(cuid())
  integrationId   String
  encryptedSecret String    @db.Text
  refreshToken    String?   @db.Text
  expiresAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  integration FirmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

model MailboxConnection {
  id            String          @id @default(cuid())
  firmId        String
  emailAddress  String
  provider      MailboxProvider
  lastSyncAt    DateTime?
  lastUid       String?         // IMAP UID cursor for incremental poll
  active        Boolean         @default(true)
  integrationId String?         // link to FirmIntegration for credentials
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  firm         Firm                @relation(fields: [firmId], references: [id], onDelete: Cascade)
  integration  FirmIntegration?    @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([firmId, active])
  @@index([integrationId])
  @@index([firmId, lastSyncAt])
}

model IntegrationSyncLog {
  id            String   @id @default(cuid())
  firmId        String
  integrationId String
  eventType     String
  status        String   // success | error | skipped
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  integration FirmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([integrationId])
  @@index([createdAt])
}

model FieldMapping {
  id            String   @id @default(cuid())
  firmId        String
  integrationId String
  sourceField   String
  targetField   String
  createdAt     DateTime @default(now())

  integration FirmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([integrationId])
}
