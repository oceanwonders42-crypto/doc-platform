generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLATFORM_ADMIN
  FIRM_ADMIN
  PARALEGAL
  STAFF
}

enum DocumentStatus {
  RECEIVED
  PROCESSING
  NEEDS_REVIEW
  UPLOADED
  FAILED
  UNMATCHED
}

enum DocumentReviewState {
  IN_REVIEW
  APPROVED
  REJECTED
  EXPORT_READY
}

enum ProcessingStage {
  uploaded
  ocr
  classification
  extraction
  case_match
  complete
}

enum ClioHandoffExportType {
  SINGLE_CASE
  BATCH
}

enum ClioHandoffExportSubtype {
  CONTACTS
  MATTERS
  COMBINED_BATCH
}

enum ClioHandoffCaseStatus {
  INCLUDED
  SKIPPED
}

model Firm {
  id                String    @id @default(cuid())
  name              String
  plan              String    @default("starter")
  pageLimitMonthly  Int       @default(5000)
  retentionDays     Int       @default(7)
  status            String    @default("active")
  billingCustomerId String?
  billingStatus     String    @default("trial")
  trialEndsAt       DateTime?
  features          Json?
  settings          Json?
  createdAt         DateTime  @default(now())

  users                       User[]
  apiKeys                     ApiKey[]
  documents                   Document[]
  usageMonthly                UsageMonthly[]
  routingRule                 RoutingRule?
  providers                   Provider[]
  cases                       LegalCase[]
  contacts                    Contact[]
  caseProviders               CaseProvider[]
  crmPushLogs                 CrmPushLog[]
  crmCaseMappings             CrmCaseMapping[]
  notifications               Notification[]
  jobs                        Job[]
  webhookEndpoints            WebhookEndpoint[]
  trafficMatters              TrafficMatter[]
  firmIntegrations            FirmIntegration[]
  mailboxConnections          MailboxConnection[]
  activityFeedItems           ActivityFeedItem[]
  caseFinancials              CaseFinancial[]
  caseSummaries               CaseSummary[]
  casePacketExports           CasePacketExport[]
  clioHandoffExports          ClioHandoffExport[]
  clioHandoffExportCases      ClioHandoffExportCase[]
  appBugReports               AppBugReport[]
  demandPackages              DemandPackage[]
  reviewQueueEvents           ReviewQueueEvent[]
  demandPackageSectionSources DemandPackageSectionSource[]
}

enum JobStatus {
  queued
  running
  failed
  done
  cancelled
}

model Job {
  id          String    @id @default(cuid())
  firmId      String?
  type        String
  payload     Json      @default("{}")
  status      JobStatus @default(queued)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  priority    Int       @default(100)
  lockedAt    DateTime?
  lockedBy    String?
  resultMeta  Json?
  lastError   String?   @db.Text
  runAt       DateTime  @default(now())
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  firm   Firm?      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  events JobEvent[]

  @@index([firmId])
  @@index([status])
  @@index([status, runAt])
  @@index([firmId, status])
  @@index([type, status])
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  level     String
  message   String   @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model User {
  id           String   @id @default(cuid())
  firmId       String
  email        String   @unique
  role         Role     @default(STAFF)
  passwordHash String?
  createdAt    DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])
}

model ApiKey {
  id         String    @id @default(cuid())
  firmId     String
  userId     String?
  name       String
  keyPrefix  String
  keyHash    String
  scopes     String    @default("ingest")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
}

model ClioHandoffExport {
  id               String                  @id @default(cuid())
  firmId           String
  exportType       ClioHandoffExportType
  exportSubtype    ClioHandoffExportSubtype
  idempotencyKey   String?
  requestFingerprint String?
  reExportOverride Boolean                 @default(false)
  reExportReason   String?                 @db.Text
  actorType        String?
  actorUserId      String?
  actorApiKeyId    String?
  actorLabel       String?
  actorRole        String?
  archiveFileName  String?
  contactsFileName String?
  mattersFileName  String?
  manifestFileName String?
  contactsRowCount Int?
  mattersRowCount  Int?
  manifestJson     Json?
  exportedAt       DateTime                @default(now())
  createdAt        DateTime                @default(now())

  firm        Firm                     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  memberships ClioHandoffExportCase[]

  @@index([firmId, exportedAt])
  @@index([firmId, exportType, exportedAt])
  @@index([firmId, requestFingerprint, exportedAt])
  @@unique([firmId, idempotencyKey])
}

model ClioHandoffExportCase {
  id         String                @id @default(cuid())
  exportId   String
  firmId     String
  caseId     String
  caseNumber String?
  caseTitle  String?
  clientName String?
  status     ClioHandoffCaseStatus
  isReExport Boolean               @default(false)
  skipReason String?               @db.Text
  createdAt  DateTime              @default(now())

  export ClioHandoffExport @relation(fields: [exportId], references: [id], onDelete: Cascade)
  firm   Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([exportId])
  @@index([firmId, caseId, createdAt])
  @@index([firmId, status, createdAt])
}

model Document {
  id                  String          @id @default(cuid())
  firmId              String
  source              String
  spacesKey           String
  originalName        String
  mimeType            String
  pageCount           Int             @default(0)
  status              DocumentStatus  @default(RECEIVED)
  processingStage     ProcessingStage @default(uploaded)
  external_id         String?
  file_sha256         String?
  fileSizeBytes       Int?
  duplicateMatchCount Int             @default(0)
  duplicateOfId       String?
  ingestedAt          DateTime        @default(now())

  extractedFields Json?
  confidence      Float?
  reviewState     DocumentReviewState?
  routedSystem    String?
  routedCaseId    String?
  routingStatus   String?

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  metaJson      Json?
  failureStage  String?
  failureReason String?
  thumbnailKey  String?

  duplicateOf Document?  @relation("DocumentDuplicate", fields: [duplicateOfId], references: [id])
  duplicates  Document[] @relation("DocumentDuplicate")

  firm Firm @relation(fields: [firmId], references: [id])

  auditEvents       DocumentAuditEvent[]
  activityFeedItems ActivityFeedItem[]

  @@index([firmId])
  @@index([status])
  @@index([firmId, file_sha256])
  @@index([firmId, reviewState])
}

model RoutingRule {
  id                     String   @id @default(cuid())
  firmId                 String   @unique
  minAutoRouteConfidence Float    @default(0.9)
  autoRouteEnabled       Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])
}

model DocumentAuditEvent {
  id         String   @id @default(cuid())
  documentId String
  firmId     String
  actor      String
  action     String
  fromCaseId String?
  toCaseId   String?
  metaJson   Json?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([firmId])
  @@index([action])
}

model UsageMonthly {
  id                     String   @id @default(cuid())
  firmId                 String
  yearMonth              String
  pagesProcessed         Int      @default(0)
  docsProcessed          Int      @default(0)
  insuranceDocsExtracted Int      @default(0)
  courtDocsExtracted     Int      @default(0)
  narrativeGenerated     Int      @default(0)
  duplicateDetected      Int      @default(0)
  updatedAt              DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id])

  @@unique([firmId, yearMonth])
  @@index([firmId])
}

model Provider {
  id               String    @id @default(cuid())
  firmId           String
  name             String
  address          String
  city             String
  state            String
  phone            String?
  fax              String?
  email            String?
  specialty        String?
  specialtiesJson  Json?
  verified         Boolean   @default(false)
  subscriptionTier String    @default("free")
  listingActive    Boolean   @default(true)
  expiresAt        DateTime?
  lat              Float?
  lng              Float?
  createdAt        DateTime  @default(now())

  firm              Firm               @relation(fields: [firmId], references: [id])
  caseProviders     CaseProvider[]
  providerAccounts  ProviderAccount[]
  providerInvites   ProviderInvite[]
  activityFeedItems ActivityFeedItem[]

  @@index([firmId])
}

model ProviderAccount {
  id           String   @id @default(cuid())
  providerId   String
  email        String   @unique
  passwordHash String
  role         String   @default("PROVIDER_ADMIN")
  createdAt    DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model ProviderInvite {
  id         String    @id @default(cuid())
  providerId String
  email      String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([email])
}

model CaseProvider {
  id           String   @id @default(cuid())
  firmId       String
  caseId       String
  providerId   String
  relationship String   @default("treating")
  createdAt    DateTime @default(now())

  firm     Firm      @relation(fields: [firmId], references: [id])
  case     LegalCase @relation(fields: [caseId], references: [id])
  provider Provider  @relation(fields: [providerId], references: [id])

  @@unique([firmId, caseId, providerId])
  @@index([firmId, providerId])
}

model RecordsRequest {
  id                  String    @id @default(cuid())
  firmId              String
  caseId              String
  providerId          String?
  providerName        String
  providerContact     String?
  dateFrom            DateTime?
  dateTo              DateTime?
  notes               String?
  letterBody          String?
  status              String    @default("DRAFT")
  generatedDocumentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  patientName       String?
  patientDob        DateTime?
  dateOfLoss        DateTime?
  requestType       String?
  destinationType   String?
  destinationValue  String?
  subject           String?
  messageBody       String?
  requestedDateFrom DateTime?
  requestedDateTo   DateTime?
  sentAt            DateTime?
  dueAt             DateTime?
  completedAt       DateTime?
  createdByUserId   String?
  followUpCount     Int       @default(0)
  lastFollowUpAt    DateTime?
  requestDate       DateTime?
  responseDate      DateTime?

  attempts    RecordsRequestAttempt[]
  events      RecordsRequestEvent[]
  attachments RecordsRequestAttachment[]

  @@index([firmId, caseId])
  @@index([firmId, status])
  @@index([firmId, dueAt])
  @@index([firmId, createdAt])
}

model RecordsRequestEvent {
  id               String   @id @default(cuid())
  firmId           String
  recordsRequestId String
  eventType        String
  status           String?
  message          String?  @db.Text
  metaJson         Json?
  createdAt        DateTime @default(now())

  recordsRequest RecordsRequest @relation(fields: [recordsRequestId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([recordsRequestId])
  @@index([createdAt])
}

model RecordsRequestTemplate {
  id          String   @id @default(cuid())
  firmId      String
  name        String
  requestType String?
  subject     String?
  body        String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firmId])
}

model RecordsRequestAttachment {
  id               String   @id @default(cuid())
  firmId           String
  recordsRequestId String
  documentId       String
  kind             String
  createdAt        DateTime @default(now())

  recordsRequest RecordsRequest @relation(fields: [recordsRequestId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([recordsRequestId])
}

model RecordsRequestFollowUpRule {
  id              String   @id @default(cuid())
  firmId          String
  enabled         Boolean  @default(true)
  daysAfterSend   Int      @default(14)
  maxFollowUps    Int      @default(3)
  messageTemplate String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([firmId])
}

model RecordsRequestAttempt {
  id               String   @id @default(cuid())
  firmId           String
  recordsRequestId String
  channel          String
  destination      String
  ok               Boolean
  error            String?  @db.Text
  externalId       String?
  createdAt        DateTime @default(now())

  recordsRequest RecordsRequest @relation(fields: [recordsRequestId], references: [id], onDelete: Cascade)

  @@index([firmId, recordsRequestId])
  @@index([recordsRequestId])
}

model LegalCase {
  id              String    @id @default(cuid())
  firmId          String
  title           String?
  caseNumber      String?
  clientName      String?
  clientContactId String?
  incidentDate    DateTime?
  status          String    @default("open")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  firm              Firm               @relation(fields: [firmId], references: [id])
  clientContact     Contact?           @relation("CaseClientContact", fields: [clientContactId], references: [id], onDelete: SetNull)
  caseProviders     CaseProvider[]
  caseNotes         CaseNote[]
  caseTasks         CaseTask[]
  caseFinancial     CaseFinancial?
  caseSummary       CaseSummary?
  casePacketExports CasePacketExport[]
  demandPackages    DemandPackage[]
  activityFeedItems ActivityFeedItem[]

  @@index([firmId])
  @@index([clientContactId])
  @@index([firmId, status])
  @@map("Case")
}

model Contact {
  id         String     @id @default(cuid())
  firmId     String
  firstName  String?
  lastName   String?
  fullName   String
  email      String?
  phone      String?
  dateOfBirth DateTime?
  address1    String?
  address2    String?
  city        String?
  state       String?
  postalCode  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  firm          Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  clientCases   LegalCase[] @relation("CaseClientContact")

  @@index([firmId])
  @@index([firmId, fullName])
  @@index([firmId, email])
}

model CaseNote {
  id           String   @id @default(cuid())
  firmId       String
  caseId       String
  authorUserId String?
  body         String   @db.Text
  createdAt    DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId, caseId])
  @@index([caseId])
}

model CaseTask {
  id          String    @id @default(cuid())
  firmId      String
  caseId      String
  title       String
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId, caseId])
  @@index([caseId])
  @@index([firmId, completedAt])
}

model ActivityFeedItem {
  id         String   @id @default(cuid())
  firmId     String
  caseId     String?
  providerId String?
  documentId String?
  type       String
  title      String
  meta       Json?
  createdAt  DateTime @default(now())

  firm     Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case     LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  provider Provider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  document Document?  @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([caseId])
  @@index([createdAt])
}

model CaseFinancial {
  id                 String   @id @default(cuid())
  firmId             String
  caseId             String   @unique
  medicalBillsTotal  Float    @default(0)
  liensTotal         Float    @default(0)
  settlementOffer    Float?
  settlementAccepted Float?
  attorneyFees       Float?
  costs              Float?
  netToClient        Float?
  updatedAt          DateTime @updatedAt

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId, caseId])
  @@index([caseId])
}

model CaseSummary {
  id        String   @id @default(cuid())
  firmId    String
  caseId    String   @unique
  body      String   @db.Text
  createdAt DateTime @default(now())

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([caseId])
}

model CasePacketExport {
  id         String   @id @default(cuid())
  firmId     String
  caseId     String
  storageKey String
  fileName   String
  packetType String   @default("combined")
  createdAt  DateTime @default(now())

  firm Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([caseId])
  @@index([createdAt])
}

model ReviewQueueEvent {
  id             String    @id @default(cuid())
  firmId         String
  documentId     String
  enteredAt      DateTime
  exitedAt       DateTime?
  resolutionType String?

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, documentId])
  @@index([firmId, enteredAt])
  @@index([exitedAt])
}

model RoutingFeedback {
  id               String   @id @default(cuid())
  firmId           String
  documentId       String
  predictedCaseId  String?
  finalCaseId      String?
  predictedStatus  String?
  finalStatus      String?
  predictedDocType String?
  finalDocType     String?
  confidence       Float?
  correctedBy      String?
  wasAccepted      Boolean  @default(false)
  featuresJson     Json?
  createdAt        DateTime @default(now())

  @@index([firmId, documentId])
  @@index([firmId, wasAccepted])
}

model RoutingPattern {
  id              String   @id @default(cuid())
  firmId          String
  name            String
  docType         String?
  providerName    String?
  source          String?
  fileNamePattern String?
  keywordsJson    Json?
  targetCaseId    String?
  targetFolder    String?
  priority        Int      @default(100)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([firmId, active, priority])
}

model RoutingScoreSnapshot {
  id             String   @id @default(cuid())
  firmId         String
  documentId     String
  chosenCaseId   String?
  chosenFolder   String?
  chosenDocType  String?
  confidence     Float?
  signalsJson    Json?
  candidatesJson Json?
  createdAt      DateTime @default(now())

  @@index([firmId, documentId])
}

model AppBugReport {
  id            String   @id @default(cuid())
  firmId        String
  userId        String?
  title         String
  description   String   @db.Text
  pageUrl       String?
  screenshotUrl String?
  status        String   @default("OPEN")
  priority      String   @default("MEDIUM")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model MedicalBillLineItem {
  id                   String    @id @default(cuid())
  firmId               String
  caseId               String
  documentId           String
  providerName         String?
  serviceDate          DateTime?
  cptCode              String?
  procedureDescription String?
  amountCharged        Decimal?
  amountPaid           Decimal?
  balance              Decimal?
  lineTotal            Decimal?
  createdAt            DateTime? @default(now())

  @@index([caseId])
  @@index([documentId])
  @@index([firmId])
}

model DemandPackage {
  id             String    @id @default(cuid())
  firmId         String
  caseId         String
  title          String
  status         String    @default("draft")
  summaryText    String?   @db.Text
  damagesText    String?   @db.Text
  liabilityText  String?   @db.Text
  treatmentText  String?   @db.Text
  futureCareText String?   @db.Text
  settlementText String?   @db.Text
  generatedDocId String?
  generatedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  firm           Firm                         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  case           LegalCase                    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sectionSources DemandPackageSectionSource[]

  @@index([firmId, caseId])
}

model DemandPackageSectionSource {
  id              String   @id @default(cuid())
  firmId          String
  demandPackageId String
  sectionKey      String
  documentId      String?
  timelineEventId String?
  sourceType      String
  sourceMeta      Json?
  createdAt       DateTime @default(now())

  firm          Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  demandPackage DemandPackage @relation(fields: [demandPackageId], references: [id], onDelete: Cascade)

  @@index([firmId, demandPackageId])
}

model CaseTimelineEvent {
  id           String    @id @default(cuid())
  caseId       String
  firmId       String
  eventDate    DateTime?
  eventType    String?
  track        String    @default("medical")
  facilityId   String?
  provider     String?
  diagnosis    String?
  procedure    String?
  amount       String?
  documentId   String
  metadataJson Json?
  createdAt    DateTime  @default(now())

  @@index([caseId, firmId])
  @@index([documentId])
  @@index([caseId, firmId, track])
}

model CaseTimelineRebuild {
  id        String   @id @default(cuid())
  caseId    String
  firmId    String
  rebuiltAt DateTime @default(now())

  @@unique([caseId, firmId])
  @@index([caseId])
}

model CrmPushLog {
  id         String   @id @default(cuid())
  firmId     String
  caseId     String
  documentId String?
  actionType String
  provider   String
  ok         Boolean
  externalId String?
  error      String?
  createdAt  DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
  @@index([caseId])
  @@index([createdAt])
}

model CrmCaseMapping {
  id               String   @id @default(cuid())
  firmId           String
  caseId           String
  externalMatterId String
  createdAt        DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@unique([firmId, caseId])
  @@index([firmId])
  @@index([externalMatterId])
}

model SystemErrorLog {
  id         String    @id @default(cuid())
  service    String
  message    String    @db.Text
  stack      String?   @db.Text
  createdAt  DateTime  @default(now())
  firmId     String?
  userId     String?
  area       String?
  route      String?
  method     String?
  severity   String?
  metaJson   Json?
  resolvedAt DateTime?
  status     String?

  @@index([service])
  @@index([createdAt])
  @@index([status])
}

model SystemBackup {
  id         String    @id @default(cuid())
  backupType String
  location   String
  size       Int       @default(0)
  checksum   String?
  createdAt  DateTime  @default(now())
  verifiedAt DateTime?
  status     String

  @@index([backupType])
  @@index([createdAt])
  @@index([status])
}

model SystemIncident {
  id             String    @id @default(cuid())
  severity       String
  title          String
  description    String?   @db.Text
  status         String
  relatedErrorId String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  firmId    String
  type      String
  title     String
  message   String?  @db.Text
  meta      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
  @@index([firmId, read])
  @@index([createdAt])
}

model WebhookEndpoint {
  id         String   @id @default(cuid())
  firmId     String
  url        String   @db.Text
  secret     String   @db.Text
  eventsJson Json?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
}

enum IntegrationType {
  EMAIL
  CASE_API
}

enum IntegrationProvider {
  GMAIL
  OUTLOOK
  CLIO
  FILEVINE
  GENERIC
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

enum MailboxProvider {
  GMAIL
  OUTLOOK
  IMAP
}

model FirmIntegration {
  id        String              @id @default(cuid())
  firmId    String
  type      IntegrationType
  provider  IntegrationProvider
  status    IntegrationStatus   @default(DISCONNECTED)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  firm               Firm                    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  credentials        IntegrationCredential[]
  mailboxConnections MailboxConnection[]
  syncLogs           IntegrationSyncLog[]
  fieldMappings      FieldMapping[]

  @@index([firmId])
  @@index([firmId, type])
  @@index([status])
}

model IntegrationCredential {
  id              String    @id @default(cuid())
  integrationId   String
  encryptedSecret String    @db.Text
  refreshToken    String?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  integration FirmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

model MailboxConnection {
  id            String          @id @default(cuid())
  firmId        String
  emailAddress  String
  provider      MailboxProvider
  lastSyncAt    DateTime?
  lastUid       String?
  active        Boolean         @default(true)
  integrationId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  firm        Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  integration FirmIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([firmId, active])
  @@index([integrationId])
}

model IntegrationSyncLog {
  id            String   @id @default(cuid())
  firmId        String
  integrationId String
  eventType     String
  status        String
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  integration FirmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([integrationId])
  @@index([createdAt])
}

model FieldMapping {
  id            String   @id @default(cuid())
  firmId        String
  integrationId String
  sourceField   String
  targetField   String
  createdAt     DateTime @default(now())

  integration FirmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([integrationId])
}

model TrafficMatter {
  id                       String    @id @default(cuid())
  firmId                   String
  caseId                   String?
  crmRecordId              String?
  crmProvider              String?
  matterType               String    @default("TRAFFIC")
  status                   String    @default("NEW_CITATION")
  documentTypeOfOrigin     String?
  sourceDocumentId         String?
  defendantName            String?
  defendantDob             DateTime?
  citationNumber           String?
  statuteCodeRaw           String?
  statuteCodeNormalized    String?
  chargeDescriptionRaw     String?
  chargeListJson           Json?
  jurisdictionState        String?
  jurisdictionCounty       String?
  courtName                String?
  courtType                String?
  issueDate                DateTime?
  dueDate                  DateTime?
  hearingDate              DateTime?
  extractedFactsJson       Json?
  extractionConfidenceJson Json?
  routingConfidence        Float?
  reviewRequired           Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([firmId, citationNumber])
  @@index([firmId, jurisdictionState])
  @@index([firmId, dueDate])
  @@index([firmId, status])
  @@index([firmId, createdAt])
}
