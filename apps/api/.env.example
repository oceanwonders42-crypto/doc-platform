# Copy to .env and fill in. Never commit .env or real secrets.

# Required for local dev/demo
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
REDIS_URL=redis://localhost:6379

# Optional (defaults)
PORT=4000

# Optional: set when tesseract is not on PATH on the host.
# TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# Optional: override language for OCR fallback.
# TESSERACT_LANGUAGE=eng

# Optional: for seed:demo:http (API key for the firm to seed)
# DOC_API_URL=http://127.0.0.1:4000
# DOC_API_KEY=sk_live_your_api_key_here
